<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Lint (InvalidWearFeatureAttribute) ожидает Wear-only APK с required="true", но это
         намеренно универсальный APK для телефона и часов (см. README «Architecture») —
         required="false" обязателен, иначе установка на телефон будет заблокирована Play/PackageManager. -->
    <uses-feature
        android:name="android.hardware.type.watch"
        android:required="false"
        tools:ignore="InvalidWearFeatureAttribute" />

    <queries>
        <intent>
            <action android:name="android.intent.action.DISMISS_ALARM" />
        </intent>
        <intent>
            <action android:name="android.intent.action.SNOOZE_ALARM" />
        </intent>
        <!-- Package visibility (API 30+): без этого queryIntentActivities(ACTION_SET_ALARM)
             в AlarmSourceApps.fromSetAlarmHandlers может вернуть пустой список. -->
        <intent>
            <action android:name="android.intent.action.SET_ALARM" />
        </intent>
    </queries>

    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <!-- Lint (ProtectedPermissions) считает это system-only по protectionLevel, но с API 31
         это специальное разрешение, доступное обычным приложениям категории "alarm" через
         Settings.ACTION_REQUEST_SCHEDULE_EXACT_ALARM (см. ExactAlarmPermission.kt). -->
    <uses-permission
        android:name="android.permission.SCHEDULE_EXACT_ALARM"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.BODY_SENSORS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.WearAlarmSync.Phone">

        <uses-library
            android:name="com.google.android.wearable"
            android:required="false" />

        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="false" />

        <activity
            android:name=".LauncherActivity"
            android:exported="true"
            android:taskAffinity=""
            android:theme="@style/Theme.WearAlarmSync.Launcher">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".phone.PhoneMainActivity"
            android:exported="false"
            android:taskAffinity=""
            android:theme="@style/Theme.WearAlarmSync.Phone" />

        <activity
            android:name=".wear.WearMainActivity"
            android:exported="false"
            android:taskAffinity=""
            android:theme="@android:style/Theme.DeviceDefault" />

        <activity
            android:name=".wear.WearVibrationSettingsActivity"
            android:exported="false"
            android:taskAffinity=""
            android:theme="@android:style/Theme.DeviceDefault" />

        <!-- showWhenLocked/turnScreenOn: no-op на minSdk 26-27 (атрибуты с API 27) — на этих
             версиях AlarmActivity.showOnLockScreen() ставит эквивалентные FLAG_SHOW_WHEN_LOCKED /
             FLAG_TURN_SCREEN_ON программно; здесь оставлены для более раннего эффекта на API 27+. -->
        <activity
            android:name=".wear.AlarmActivity"
            android:exported="false"
            android:launchMode="singleTop"
            android:showOnLockScreen="true"
            android:showWhenLocked="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.DeviceDefault"
            android:turnScreenOn="true"
            tools:ignore="UnusedAttribute" />

        <receiver
            android:name=".phone.NextAlarmReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.app.action.NEXT_ALARM_CLOCK_CHANGED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".phone.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".wear.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".wear.AlarmReceiver"
            android:exported="false" />

        <service
            android:name=".phone.AlarmCommandListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED" />
                <data
                    android:host="*"
                    android:pathPrefix="/alarm_command"
                    android:scheme="wear" />
            </intent-filter>
        </service>

        <service
            android:name=".wear.AlarmKeepAliveService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="alarm-clock-watch-companion" />
        </service>

        <service
            android:name=".wear.AlarmDataListenerService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data
                    android:host="*"
                    android:pathPrefix="/alarms"
                    android:scheme="wear" />
            </intent-filter>
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.DATA_CHANGED" />
                <data
                    android:host="*"
                    android:pathPrefix="/settings"
                    android:scheme="wear" />
            </intent-filter>
        </service>
    </application>
</manifest>
